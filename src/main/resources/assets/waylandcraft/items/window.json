{
	"model": {
		"type": "minecraft:select",
		"property": "waylandcraft:window_state",
		"cases": [
			{
				"when": "none",
				"model": {
					"type": "minecraft:model",
					"model": "waylandcraft:item/window"
				}
			},
			{
				"when": "broken",
				"model": {
					"type": "minecraft:model",
					"model": "waylandcraft:item/broken_window"
				}
			},
			{
				"when": "icon",
				"model": {
					"type": "minecraft:special",
					"base": "waylandcraft:item/window",
					"model": {
						"type": "waylandcraft:window"
					}
				}
			}
		]
	}
}
